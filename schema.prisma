generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SELLER
  RECRUITER
  ADMIN
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum AffiliateStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum RecruiterStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum SellerPlanCode {
  FREE
  SILVER
  GOLD
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentProvider {
  CASH_ON_DELIVERY
  MANUAL_CONFIRMATION
  PAYMOB
  FAWRY
  STRIPE
  VISA
  MASTERCARD
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum WalletOwnerType {
  PLATFORM
  SELLER
  AFFILIATE
  RECRUITER
}

enum WalletTransactionType {
  SALE_CREDIT
  PLATFORM_COMMISSION
  AFFILIATE_COMMISSION
  RECRUITER_COMMISSION
  REFUND_DEBIT
  PAYOUT
  ADJUSTMENT
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String            @id @default(cuid())
  name          String
  email         String            @unique
  passwordHash  String
  role          UserRole          @default(CUSTOMER)
  locale        String            @default("en")
  sellerProfile SellerProfile?
  affiliateProfile AffiliateProfile?
  recruiterProfile RecruiterProfile?
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  orders        Order[]
  reviews       Review[]
  notifications Notification[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model SellerProfile {
  id          String        @id @default(cuid())
  userId      String        @unique
  user        User          @relation(fields: [userId], references: [id])
  storeName   String
  storeSlug   String        @unique
  phone       String?
  status      SellerStatus  @default(PENDING)
  approvedAt  DateTime?
  balanceEGP  Decimal       @default(0)
  planId      String?
  plan        SellerPlan?    @relation(fields: [planId], references: [id])
  recruiterId String?
  recruiter   RecruiterProfile? @relation(fields: [recruiterId], references: [id])
  products    Product[]
  orders      OrderItem[]
  recruiterCommissions RecruiterCommission[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model SellerPlan {
  id                String         @id @default(cuid())
  code              SellerPlanCode @unique
  nameEn            String
  nameAr            String
  maxProducts       Int
  searchBoost       Int            @default(0)
  advancedAnalytics Boolean        @default(false)
  supportLevel      String
  isActive          Boolean        @default(true)
  sellers           SellerProfile[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model AffiliateProfile {
  id                 String          @id @default(cuid())
  userId             String          @unique
  user               User            @relation(fields: [userId], references: [id])
  referralCode       String          @unique
  status             AffiliateStatus @default(PENDING)
  commissionPercent  Decimal?
  approvedAt         DateTime?
  balanceEGP         Decimal         @default(0)
  referrals          AffiliateReferral[]
  sales              AffiliateSale[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model RecruiterProfile {
  id                    String          @id @default(cuid())
  userId                String          @unique
  user                  User            @relation(fields: [userId], references: [id])
  referralCode          String          @unique
  status                RecruiterStatus @default(PENDING)
  fixedCommissionEGP    Decimal?
  platformCommissionSharePercent Decimal?
  approvedAt            DateTime?
  balanceEGP            Decimal         @default(0)
  recruitedSellers      SellerProfile[]
  commissions           RecruiterCommission[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model RecruiterCommission {
  id            String           @id @default(cuid())
  recruiterId   String
  recruiter     RecruiterProfile @relation(fields: [recruiterId], references: [id])
  sellerId      String
  seller        SellerProfile    @relation(fields: [sellerId], references: [id])
  orderId       String?
  amountEGP     Decimal
  basis         String
  status        PaymentStatus    @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Category {
  id                         String    @id @default(cuid())
  nameEn                     String
  nameAr                     String
  slug                       String    @unique
  commissionPercent          Decimal?
  affiliateCommissionPercent Decimal?
  products                   Product[]
  coupons                    Coupon[]
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
}

model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logoUrl   String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id                         String         @id @default(cuid())
  sellerId                   String
  seller                     SellerProfile  @relation(fields: [sellerId], references: [id])
  categoryId                 String
  category                   Category       @relation(fields: [categoryId], references: [id])
  brandId                    String?
  brand                      Brand?         @relation(fields: [brandId], references: [id])
  nameEn                     String
  nameAr                     String
  slug                       String         @unique
  metaTitle                  String?
  metaDescription            String?
  descriptionEn              String
  descriptionAr              String
  priceEGP                   Decimal
  stock                      Int            @default(0)
  lowStockThreshold          Int            @default(5)
  rating                     Float          @default(0)
  ratingCount                Int            @default(0)
  status                     ProductStatus  @default(PENDING_REVIEW)
  commissionPercent          Decimal?
  affiliateCommissionPercent Decimal?
  images                     ProductImage[]
  variants                   ProductVariant[]
  inventoryMovements         InventoryLedger[]
  cartItems                  CartItem[]
  wishlistItems              WishlistItem[]
  orderItems                 OrderItem[]
  reviews                    Review[]
  affiliateReferrals         AffiliateReferral[]
  featured                   Boolean        @default(false)
  bestSeller                 Boolean        @default(false)
  newArrival                 Boolean        @default(false)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  sku        String   @unique
  priceEGP   Decimal?
  stock      Int      @default(0)
  attributes Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String
  sortOrder Int      @default(0)
}

model InventoryLedger {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  change    Int
  reason    String
  reference String?
  createdAt DateTime @default(now())
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  type           CouponType
  value          Decimal
  categoryId     String?
  category       Category?  @relation(fields: [categoryId], references: [id])
  usageLimit     Int?
  usageCount     Int        @default(0)
  expiresAt      DateTime?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model ShippingZone {
  id                 String   @id @default(cuid())
  nameEn             String
  nameAr             String
  city               String
  feeEGP             Decimal
  deliveryEstimate   String
  codEnabled         Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Order {
  id                   String          @id @default(cuid())
  customerId           String
  customer             User            @relation(fields: [customerId], references: [id])
  orderNumber          String          @unique
  status               OrderStatus     @default(PENDING)
  paymentProvider      PaymentProvider @default(CASH_ON_DELIVERY)
  paymentStatus        PaymentStatus   @default(PENDING)
  paymentTransactionId String?
  affiliateCode        String?
  couponCode           String?
  subtotalEGP          Decimal
  discountEGP          Decimal         @default(0)
  platformCommissionEGP Decimal
  affiliateCommissionEGP Decimal       @default(0)
  sellerEarningEGP     Decimal
  deliveryFeeEGP       Decimal         @default(0)
  totalEGP             Decimal
  customerName         String
  phone                String
  address              String
  city                 String
  notes                String?
  items                OrderItem[]
  affiliateSales       AffiliateSale[]
  paymentTransactions  PaymentTransaction[]
  refunds              Refund[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model OrderItem {
  id                         String        @id @default(cuid())
  orderId                    String
  order                      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId                  String
  product                    Product       @relation(fields: [productId], references: [id])
  sellerId                   String
  seller                     SellerProfile @relation(fields: [sellerId], references: [id])
  quantity                   Int
  unitPriceEGP               Decimal
  platformCommissionPercent  Decimal
  affiliateCommissionPercent Decimal       @default(0)
  platformCommissionEGP      Decimal
  affiliateCommissionEGP     Decimal       @default(0)
  sellerEarningEGP           Decimal
}

model AffiliateReferral {
  id          String           @id @default(cuid())
  affiliateId String
  affiliate  AffiliateProfile @relation(fields: [affiliateId], references: [id])
  productId   String
  product     Product          @relation(fields: [productId], references: [id])
  referralUrl String
  clicks      Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model AffiliateSale {
  id                String           @id @default(cuid())
  affiliateId       String
  affiliate         AffiliateProfile @relation(fields: [affiliateId], references: [id])
  orderId           String
  order             Order            @relation(fields: [orderId], references: [id])
  commissionEGP     Decimal
  status            PaymentStatus    @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Wallet {
  id          String          @id @default(cuid())
  ownerType   WalletOwnerType
  ownerId     String
  currency    String          @default("EGP")
  balanceEGP  Decimal         @default(0)
  transactions WalletTransaction[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([ownerType, ownerId])
}

model WalletTransaction {
  id          String                @id @default(cuid())
  walletId    String
  wallet      Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        WalletTransactionType
  amountEGP   Decimal
  balanceAfterEGP Decimal
  reference   String?
  description String
  createdAt   DateTime              @default(now())
}

model PaymentTransaction {
  id            String          @id @default(cuid())
  orderId       String
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider      PaymentProvider
  providerRef   String?
  amountEGP     Decimal
  status        PaymentStatus   @default(PENDING)
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Refund {
  id          String        @id @default(cuid())
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amountEGP   Decimal
  reason      String
  status      PaymentStatus @default(PENDING)
  providerRef String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Review {
  id              String       @id @default(cuid())
  productId       String
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  rating          Int
  title           String
  body            String
  verifiedBuyer   Boolean      @default(false)
  status          ReviewStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime @default(now())
}

model Banner {
  id        String   @id @default(cuid())
  titleEn   String
  titleAr   String
  imageUrl  String
  linkUrl   String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformSetting {
  id                                String   @id @default("platform")
  globalCommissionPercent           Decimal  @default(10)
  globalAffiliateCommissionPercent  Decimal  @default(3)
  recruiterFixedCommissionEGP       Decimal  @default(150)
  recruiterPlatformCommissionSharePercent Decimal @default(5)
  currency                          String   @default("EGP")
  manualPaymentsEnabled             Boolean  @default(true)
  codEnabled                        Boolean  @default(true)
  whatsappSupportNumber             String   @default("+201124460043")
  googleAnalyticsId                 String?
  metaPixelId                       String?
  tiktokPixelId                     String?
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt
}
